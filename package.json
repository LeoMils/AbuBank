{
  "name": "abu-bank",
  "private": true,
  "version": "30.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare": "git config core.hooksPath .githooks",
    "generate:memory": "npx tsx scripts/generate-memory-from-knowledge.ts",
    "validate:family": "npx tsx scripts/validate-family-data.ts",
    "prebuild": "npm run generate:memory && npm run validate:family",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run"
  },
  "dependencies": {
    "@google/stitch-sdk": "^0.0.3",
    "@phosphor-icons/react": "^2.1.7",
    "@types/ws": "^8.18.1",
    "edge-tts": "^1.0.1",
    "idb": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite-plugin-pwa": "^0.21.1",
    "ws": "^8.20.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.14",
    "vitest": "^4.1.4"
  }
}
