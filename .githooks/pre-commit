#!/bin/sh
#
# Pre-commit hook: validates family data + runs tests before every commit.
# If either fails, the commit is blocked.
#
# Setup: git config core.hooksPath .githooks
# Or:    npm run prepare
#

echo "🔍 Pre-commit: validating family data..."
npm run validate:family --silent
VALIDATE_EXIT=$?

if [ $VALIDATE_EXIT -ne 0 ]; then
  echo ""
  echo "❌ COMMIT BLOCKED: family data validation failed."
  echo "   Fix knowledge/family_data.json then try again."
  echo ""
  exit 1
fi

echo "🧪 Pre-commit: running tests..."
npm test --silent
TEST_EXIT=$?

if [ $TEST_EXIT -ne 0 ]; then
  echo ""
  echo "❌ COMMIT BLOCKED: tests failed."
  echo "   Fix failing tests then try again."
  echo ""
  exit 1
fi

echo "✅ Pre-commit: all checks passed."
